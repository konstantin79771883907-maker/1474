# School Support CRM - Nginx конфигурация

# Основной сервер для CRM приложения
server {
    listen 80;
    server_name your-domain.com;  # Замените на ваш домен или IP
    
    # Логи
    access_log /var/log/school-crm-access.log;
    error_log /var/log/school-crm-error.log;
    
    # Основное приложение (порт 8000)
    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Для WebSocket (если понадобится)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        
        # Таймауты
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
    
    # Deploy hook (порт 8001) - ограничиваем доступ по IP
    location /deploy-hook {
        # Разрешить только GitHub IPs (опционально)
        # allow 140.82.112.0/20;
        # allow 140.82.113.0/24;
        # deny all;
        
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        
        # Увеличиваем лимит размера тела запроса для вебхуков
        client_max_body_size 10M;
    }
    
    # Статические файлы (опционально, если будете их использовать)
    location /static {
        alias /workspace/static;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}

